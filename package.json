{
  "name": "@jyostudio/markdown",
  "version": "0.0.2",
  "description": "A markdown parser and renderer.",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "unpkg": "dist/index.js",
  "jsdelivr": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "scripts": {
    "publish": "npm publish --access public",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "prettier --write ./src",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && node esbuild.config.js",
    "build:dev": "npm run clean && tsc -p tsconfig.build.json && node esbuild.config.js --dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jyostudio/markdown.git"
  },
  "keywords": [
    "markdown"
  ],
  "author": "nivk",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jyostudio/markdown/issues"
  },
  "homepage": "https://github.com/jyostudio/markdown#readme",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-proposal-explicit-resource-management": "^7.27.4",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@jyostudio/enum": "^0.1.4",
    "@jyostudio/overload": "^0.1.14",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@jyostudio/list": "^0.1.13",
    "css-paint-polyfill": "^3.4.0"
  }
}
