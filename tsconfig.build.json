{
    "extends": "./tsconfig.json",
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "moduleResolution": "Bundler",
        "module": "ESNext",
        "allowImportingTsExtensions": false,
        "verbatimModuleSyntax": false,
        "rewriteRelativeImportExtensions": true
    }
}